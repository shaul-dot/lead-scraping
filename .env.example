# ─── Infrastructure ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hyperscale_leads
REDIS_URL=redis://localhost:6379

# ─── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# ─── AI / LLM (required) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Search ───────────────────────────────────────────────────
EXA_API_KEY=

# ─── Scraping ─────────────────────────────────────────────────
# Apify (recommended — Tier 2 managed scraping)
APIFY_TOKEN=
# Meta Graph API (optional — Tier 1 direct API, requires developer approval)
META_ACCESS_TOKEN=

# When true, scraped leads are saved as RAW but do NOT enqueue downstream pipeline jobs (dedup/enrich/etc.).
SCRAPE_ONLY=false

# ─── Enrichment (at least 1 required) ────────────────────────
APOLLO_API_KEY=
SNOVIO_API_KEY=
SNOVIO_API_SECRET=
GETPROSPECT_API_KEY=
LUSHA_API_KEY=

# ─── Email Verification (required for pipeline) ──────────────
NEVERBOUNCE_API_KEY=
BOUNCEBAN_API_KEY=

# ─── Outreach (required) ─────────────────────────────────────
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=

# ─── Deliverability Monitoring (optional) ─────────────────────
HETRIXTOOLS_API_KEY=
GOOGLE_POSTMASTER_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GLOCKAPPS_API_KEY=

# ─── Proxy (needed for Instagram scraping) ────────────────────
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# ─── Slack Notifications (optional) ──────────────────────────
SLACK_WEBHOOK_ALERTS=
SLACK_WEBHOOK_REPLIES=
SLACK_WEBHOOK_DAILY=
SLACK_WEBHOOK_STRATEGY=
SLACK_WEBHOOK_ESCALATIONS=

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
